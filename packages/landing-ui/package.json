{
	"name": "@ewanc26/landing-ui",
	"version": "0.1.0",
	"description": "Shared landing page layout and CSS for @ewanc26/*-web projects",
	"author": "Ewan Croft",
	"license": "AGPL-3.0-only",
	"type": "module",
	"keywords": [
		"svelte",
		"sveltekit",
		"landing",
		"layout"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ewanc26/pkgs.git",
		"directory": "packages/landing-ui"
	},
	"homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/landing-ui",
	"bugs": {
		"url": "https://github.com/ewanc26/pkgs/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"src"
	],
	"exports": {
		"./landing.css": {
			"source": "./src/lib/landing.css",
			"default": "./src/lib/landing.css"
		},
		".": {
			"source": "./src/lib/index.ts",
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		}
	},
	"svelte": "./src/lib/index.ts",
	"types": "./src/lib/index.ts",
	"scripts": {
		"build": "svelte-package -i src/lib -o dist",
		"dev": "svelte-package -i src/lib -o dist --watch",
		"check": "svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@lucide/svelte": "^0.575.0"
	},
	"peerDependencies": {
		"svelte": ">=5.0.0"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3"
	}
}
