{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"target": "es2022",
		"module": "esnext",
		"lib": ["es2022", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts", "src/**/*.svelte"],
	"exclude": ["node_modules", "dist"]
}
