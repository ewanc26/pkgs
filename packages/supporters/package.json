{
  "name": "@ewanc26/supporters",
  "version": "0.3.0",
  "description": "SvelteKit component library for displaying Ko-fi supporters, backed by an ATProto PDS.",
  "author": "Ewan Croft",
  "license": "AGPL-3.0-only",
  "type": "module",
  "keywords": [
    "svelte",
    "atproto",
    "ko-fi",
    "supporters",
    "webhook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewanc26/pkgs.git",
    "directory": "packages/supporters"
  },
  "homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/supporters",
  "bugs": {
    "url": "https://github.com/ewanc26/pkgs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "lexicons",
    "scripts",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pnpm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync && svelte-package -i src/lib -o dist || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ewanc26/tid": "workspace:*",
    "@lucide/svelte": "^0.575.0"
  },
  "peerDependencies": {
    "@atproto/api": ">=0.13.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@atproto/api": "^0.19.3",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.18",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
