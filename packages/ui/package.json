{
  "name": "@ewanc26/ui",
  "version": "0.3.8",
  "description": "Svelte UI component library extracted from ewancroft.uk — pluggable layout, UI primitives, stores, and SEO components.",
  "author": "Ewan Croft",
  "license": "AGPL-3.0-only",
  "type": "module",
  "keywords": [
    "svelte",
    "sveltekit",
    "components",
    "ui",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewanc26/pkgs.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/ui",
  "bugs": {
    "url": "https://github.com/ewanc26/pkgs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./styles/pds-tokens.css": {
      "source": "./src/lib/styles/pds-tokens.css",
      "default": "./dist/styles/pds-tokens.css"
    },
    ".": {
      "source": "./src/lib/index.ts",
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "svelte-package -i src/lib -o dist",
    "dev": "svelte-package -i src/lib -o dist --watch",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@ewanc26/noise-avatar": "workspace:*",
    "@lucide/svelte": "^0.577.0"
  },
  "optionalDependencies": {
    "@ewanc26/atproto": ">=0.2.2"
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2.8.3",
    "svelte": ">=5.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.3.10",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3"
  }
}
