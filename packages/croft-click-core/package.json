  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "@ewanc26/tid": "workspace:*",
    "@ipld/car": "^5.3.2",
    "@ipld/dag-cbor": "^9.2.2",
    "multiformats": "^13.3.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
