{
	"name": "@ewanc26/og",
	"version": "0.1.6",
	"description": "Dynamic OpenGraph image generator with noise backgrounds, bold typography, and Satori-based rendering. Works in SvelteKit endpoints, edge runtimes, and build scripts.",
	"author": "Ewan Croft",
	"license": "AGPL-3.0-only",
	"type": "module",
	"keywords": [
		"og",
		"opengraph",
		"image",
		"satori",
		"sveltekit",
		"seo",
		"social"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ewanc26/pkgs.git",
		"directory": "packages/og"
	},
	"homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/og",
	"bugs": {
		"url": "https://github.com/ewanc26/pkgs/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"src",
		"fonts"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./templates": {
			"types": "./dist/templates/index.d.ts",
			"import": "./dist/templates/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"prebuild": "node scripts/prebuild.mjs",
		"build": "tsup",
		"dev": "node scripts/prebuild.mjs && tsup --watch",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@ewanc26/noise": "^0.1.3",
		"@resvg/resvg-js": "^2.6.0",
		"satori": "^0.15.2"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
