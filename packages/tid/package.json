{
  "name": "@ewanc26/tid",
  "version": "1.1.3",
  "description": "Zero-dependency AT Protocol TID generation for Node.js and browsers",
  "author": "Ewan Croft",
  "license": "AGPL-3.0-only",
  "type": "module",
  "keywords": [
    "atproto",
    "bluesky",
    "tid",
    "timestamp",
    "identifier",
    "lexicon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewanc26/pkgs.git",
    "directory": "packages/tid"
  },
  "homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/tid",
  "bugs": {
    "url": "https://github.com/ewanc26/pkgs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepare": "pnpm run build",
    "type-check": "tsc --noEmit",
    "test": "node --test dist/index.test.js"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
