{
  "name": "@ewanc26/pds-landing",
  "version": "2.0.8",
  "description": "Composable Svelte components for an ATProto PDS landing page — terminal-aesthetic UI with live status fetching.",
  "author": "Ewan Croft",
  "license": "AGPL-3.0-only",
  "type": "module",
  "keywords": [
    "svelte",
    "atproto",
    "bluesky",
    "pds",
    "landing-page"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ewanc26/pkgs.git",
    "directory": "packages/pds-landing"
  },
  "homepage": "https://github.com/ewanc26/pkgs/tree/main/packages/pds-landing",
  "bugs": {
    "url": "https://github.com/ewanc26/pkgs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pnpm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ewanc26/ui": "workspace:*"
  },
  "peerDependencies": {
    "@sveltejs/kit": ">=2.0.0",
    "svelte": "^5.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.18",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
